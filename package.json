{
  "name": "opticore-react-native",
  "version": "1.0.0",
  "description": "Pure infrastructure library for React Native/Expo applications",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js"
    },
    "./utils": {
      "types": "./dist/src/utils/index.d.ts",
      "import": "./dist/src/utils/index.js",
      "require": "./dist/src/utils/index.js"
    },
    "./state": {
      "types": "./dist/src/state/index.d.ts",
      "import": "./dist/src/state/index.js",
      "require": "./dist/src/state/index.js"
    },
    "./hooks": {
      "types": "./dist/src/hooks/index.d.ts",
      "import": "./dist/src/hooks/index.js",
      "require": "./dist/src/hooks/index.js"
    }
  },
  "scripts": {
    "start": "tsc --watch",
    "build": "rm -rf dist && tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "validate": "npm run type-check && npm run lint && npm run format:check && npm run test",
    "test:types": "tsd",
    "clean": "rm -rf dist coverage node_modules"
  },
  "keywords": [
    "react-native",
    "expo",
    "infrastructure",
    "utilities",
    "typescript"
  ],
  "author": "Mahmoud El Shenawy",
  "license": "MIT",
  "private": false,
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "expo": "^54.0.33",
    "expo-router": "^6.0.0",
    "react": "^19.0.0",
    "react-native": ">=0.78.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.0-beta.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^19.0.8",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^54.0.10",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.17",
    "prettier": "^3.4.0",
    "react": "^19.2.4",
    "react-native": "^0.83.1",
    "test-renderer": "^0.14.0",
    "tsd": "^0.33.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/netinfo": "^11.5.1",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.13.4",
    "date-fns": "^4.1.0",
    "expo-modules-core": "^3.0.29",
    "expo-secure-store": "^15.0.8",
    "immer": "^10.2.0",
    "react-native-device-info": "^15.0.1",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "react-test-renderer": "19.2.4"
  }
}
